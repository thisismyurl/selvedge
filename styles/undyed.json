{
  "$schema": "https://schemas.wp.org/wp/6.7/theme.json",
  "version": 3,
  "title": "Undyed",
  "settings": {
    "custom": {
      "colophon-light": "#f2ede0",
      "colophon-dark": "#2a1f14",
      "colophon-accent": "#8a6b4a"
    },
    "color": {
      "palette": [
        {
          "slug": "ink",
          "color": "#2a1f14",
          "name": "Ink"
        },
        {
          "slug": "ink-secondary",
          "color": "#4a3828",
          "name": "Ink Secondary"
        },
        {
          "slug": "ink-muted",
          "color": "#645440",
          "name": "Ink Muted"
        },
        {
          "slug": "ink-faint",
          "color": "#b8a890",
          "name": "Ink Faint"
        },
        {
          "slug": "ground",
          "color": "#f2ede0",
          "name": "Ground"
        },
        {
          "slug": "ground-mid",
          "color": "#e8e0d0",
          "name": "Ground Mid"
        },
        {
          "slug": "ground-deep",
          "color": "#d8ccc0",
          "name": "Ground Deep"
        },
        {
          "slug": "indigo",
          "color": "#6F5232",
          "name": "Indigo"
        },
        {
          "slug": "indigo-light",
          "color": "#c4a880",
          "name": "Indigo Light"
        },
        {
          "slug": "footer-bg",
          "color": "#2a1f14",
          "name": "Footer Ground (edition-stable dark)"
        },
        {
          "slug": "footer-fg",
          "color": "#f2ede0",
          "name": "Footer Text (edition-stable light)"
        },
        {
          "slug": "footer-meta",
          "color": "#C8B8A8",
          "name": "Footer Meta (edition-stable muted light)"
        },
        {
          "slug": "footer-accent",
          "color": "#DCA062",
          "name": "Footer Accent (edition-stable, large/UI only)"
        }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--ground)",
      "text": "var(--wp--preset--color--ink)"
    }
  }
}
