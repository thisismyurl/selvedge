{
  "$schema": "https://schemas.wp.org/wp/6.7/theme.json",
  "version": 3,
  "title": "Nightweave",
  "settings": {
    "color": {
      "palette": [
        {
          "slug": "ink",
          "color": "#F0EBE0",
          "name": "Ink"
        },
        {
          "slug": "ink-secondary",
          "color": "#D0C8BC",
          "name": "Ink Secondary"
        },
        {
          "slug": "ink-muted",
          "color": "#9A9288",
          "name": "Ink Muted"
        },
        {
          "slug": "ink-faint",
          "color": "#6A6460",
          "name": "Ink Faint"
        },
        {
          "slug": "ground",
          "color": "#1A2040",
          "name": "Ground"
        },
        {
          "slug": "ground-mid",
          "color": "#222848",
          "name": "Ground Mid"
        },
        {
          "slug": "ground-deep",
          "color": "#2C3450",
          "name": "Ground Deep"
        },
        {
          "slug": "indigo",
          "color": "#6880D0",
          "name": "Indigo"
        },
        {
          "slug": "indigo-light",
          "color": "#151C3A",
          "name": "Indigo Light"
        },
        {
          "slug": "weld",
          "color": "#D4800E",
          "name": "Weld"
        },
        {
          "slug": "rule",
          "color": "#30384A",
          "name": "Rule"
        },
        {
          "slug": "white",
          "color": "#F8F5F0",
          "name": "White"
        }
      ]
    },
    "custom": {
      "colophon-light": "#1A2040",
      "colophon-dark": "#F0EBE0",
      "colophon-accent": "#6880D0"
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--ground)",
      "text": "var(--wp--preset--color--ink)"
    },
    "elements": {
      "heading": {
        "color": {
          "text": "var(--wp--preset--color--ink)"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--indigo)"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--ink)"
          }
        }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--indigo)",
          "text": "var(--wp--preset--color--ground)"
        }
      }
    },
    "blocks": {
      "core/site-title": {
        "color": {
          "text": "var(--wp--preset--color--ink)"
        }
      },
      "core/navigation": {
        "color": {
          "text": "var(--wp--preset--color--ink-secondary)"
        }
      }
    }
  }
}
