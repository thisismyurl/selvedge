{
  "$schema": "https://schemas.wp.org/wp/6.7/theme.json",
  "version": 3,
  "title": "Woad",
  "settings": {
    "custom": {
      "colophon-light": "#162030",
      "colophon-dark": "#e0dcd4",
      "colophon-accent": "#7ab0cc"
    },
    "color": {
      "palette": [
        {
          "slug": "ink",
          "color": "#e0dcd4",
          "name": "Ink"
        },
        {
          "slug": "ink-secondary",
          "color": "#b8b4ac",
          "name": "Ink Secondary"
        },
        {
          "slug": "ink-muted",
          "color": "#9CB0BC",
          "name": "Ink Muted"
        },
        {
          "slug": "ink-faint",
          "color": "#5c5850",
          "name": "Ink Faint"
        },
        {
          "slug": "ground",
          "color": "#162030",
          "name": "Ground"
        },
        {
          "slug": "ground-mid",
          "color": "#1C2738",
          "name": "Ground Mid"
        },
        {
          "slug": "ground-deep",
          "color": "#22304A",
          "name": "Ground Deep"
        },
        {
          "slug": "indigo",
          "color": "#9CCBE2",
          "name": "Indigo"
        },
        {
          "slug": "indigo-light",
          "color": "#284058",
          "name": "Indigo Light"
        },
        {
          "slug": "footer-bg",
          "color": "#101826",
          "name": "Footer Ground (edition-stable dark)"
        },
        {
          "slug": "footer-fg",
          "color": "#e0dcd4",
          "name": "Footer Text (edition-stable light)"
        },
        {
          "slug": "footer-meta",
          "color": "#A6BCCA",
          "name": "Footer Meta (edition-stable muted light)"
        },
        {
          "slug": "footer-accent",
          "color": "#9CCBE2",
          "name": "Footer Accent (edition-stable, large/UI only)"
        }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--ground)",
      "text": "var(--wp--preset--color--ink)"
    },
    "elements": {
      "button": {
        "color": {
          "background": "var(--wp--preset--color--indigo)",
          "text": "var(--wp--preset--color--ground)"
        }
      }
    }
  }
}
