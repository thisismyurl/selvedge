{
  "$schema": "https://schemas.wp.org/wp/6.7/theme.json",
  "version": 3,
  "title": "Natural",
  "settings": {
    "color": {
      "palette": [
        {
          "slug": "ink",
          "color": "#2A1E14",
          "name": "Ink"
        },
        {
          "slug": "ink-secondary",
          "color": "#4A3828",
          "name": "Ink Secondary"
        },
        {
          "slug": "ink-muted",
          "color": "#8A7060",
          "name": "Ink Muted"
        },
        {
          "slug": "ink-faint",
          "color": "#C0B0A0",
          "name": "Ink Faint"
        },
        {
          "slug": "ground",
          "color": "#FAF7F2",
          "name": "Ground"
        },
        {
          "slug": "ground-mid",
          "color": "#F0ECE4",
          "name": "Ground Mid"
        },
        {
          "slug": "ground-deep",
          "color": "#E4DDD0",
          "name": "Ground Deep"
        },
        {
          "slug": "indigo",
          "color": "#8A7050",
          "name": "Indigo"
        },
        {
          "slug": "indigo-light",
          "color": "#F0E8D8",
          "name": "Indigo Light"
        },
        {
          "slug": "weld",
          "color": "#9A6830",
          "name": "Weld"
        },
        {
          "slug": "rule",
          "color": "#C8B8A0",
          "name": "Rule"
        },
        {
          "slug": "white",
          "color": "#FFFFFF",
          "name": "White"
        }
      ]
    },
    "custom": {
      "colophon-light": "#FAF7F2",
      "colophon-dark": "#2A1E14",
      "colophon-accent": "#8A7050"
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--ground)",
      "text": "var(--wp--preset--color--ink)"
    },
    "elements": {
      "heading": {
        "color": {
          "text": "var(--wp--preset--color--ink)"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--indigo)"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--ink)"
          }
        }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--ink)",
          "text": "var(--wp--preset--color--ground)"
        }
      }
    },
    "blocks": {
      "core/site-title": {
        "color": {
          "text": "var(--wp--preset--color--ink)"
        }
      },
      "core/navigation": {
        "color": {
          "text": "var(--wp--preset--color--ink-secondary)"
        }
      }
    }
  }
}
