{
  "$schema": "https://schemas.wp.org/wp/6.7/theme.json",
  "version": 3,
  "title": "Indigo Vat",
  "settings": {
    "color": {
      "palette": [
        {
          "slug": "ink",
          "color": "#C8D4F0",
          "name": "Ink"
        },
        {
          "slug": "ink-secondary",
          "color": "#A0AEDD",
          "name": "Ink Secondary"
        },
        {
          "slug": "ink-muted",
          "color": "#93A0CE",
          "name": "Ink Muted"
        },
        {
          "slug": "ink-faint",
          "color": "#4A5A90",
          "name": "Ink Faint"
        },
        {
          "slug": "ground",
          "color": "#1E2B5A",
          "name": "Ground"
        },
        {
          "slug": "ground-mid",
          "color": "#263460",
          "name": "Ground Mid"
        },
        {
          "slug": "ground-deep",
          "color": "#1A2250",
          "name": "Ground Deep"
        },
        {
          "slug": "indigo",
          "color": "#9CB0EE",
          "name": "Indigo"
        },
        {
          "slug": "indigo-light",
          "color": "#121B3C",
          "name": "Indigo Light"
        },
        {
          "slug": "weld",
          "color": "#C48A20",
          "name": "Weld"
        },
        {
          "slug": "rule",
          "color": "#2A3560",
          "name": "Rule"
        },
        {
          "slug": "white",
          "color": "#F0F4FF",
          "name": "White"
        },
        {
          "slug": "footer-bg",
          "color": "#121B3C",
          "name": "Footer Ground (edition-stable dark)"
        },
        {
          "slug": "footer-fg",
          "color": "#F0F4FF",
          "name": "Footer Text (edition-stable light)"
        },
        {
          "slug": "footer-meta",
          "color": "#AEB8E2",
          "name": "Footer Meta (edition-stable muted light)"
        },
        {
          "slug": "footer-accent",
          "color": "#E6AE4E",
          "name": "Footer Accent (edition-stable, large/UI only)"
        }
      ]
    },
    "custom": {
      "colophon-light": "#1E2B5A",
      "colophon-dark": "#C8D4F0",
      "colophon-accent": "#C48A20"
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--ground)",
      "text": "var(--wp--preset--color--ink)"
    },
    "elements": {
      "heading": {
        "color": {
          "text": "var(--wp--preset--color--white)"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--indigo)"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--white)"
          }
        }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--weld)",
          "text": "var(--wp--preset--color--ground)"
        }
      }
    },
    "blocks": {
      "core/site-title": {
        "color": {
          "text": "var(--wp--preset--color--white)"
        }
      },
      "core/navigation": {
        "color": {
          "text": "var(--wp--preset--color--ink)"
        }
      }
    }
  }
}
